{
  "name": "@dreamer/web3",
  "version": "1.2.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client/mod.ts"
  },
  "tasks": {
    "test": "deno test -A tests/utils.test.ts tests/client-mod.test.ts",
    "test:integration": "deno test -A tests/mod.test.ts",
    "build": "deno run -A build-browser.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "dist/*.js",
      "dist/*.d.ts",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**",
      "dist/meta.json"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "imports": {
    "viem": "npm:viem@2.46.2",
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.1.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.2.2",
    "@dreamer/service": "jsr:@dreamer/service@^1.1.0",
    "@dreamer/test": "jsr:@dreamer/test@^1.2.3"
  },
  "nodeModulesDir": "auto",
  "minimumDependencyAge": 0
}
