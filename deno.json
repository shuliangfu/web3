{
  "name": "@dreamer/web3",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client/mod.ts"
  },
  "tasks": {
    "test": "bun test -A tests/*",
    "build": "deno run -A build-browser.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "dist/*.js",
      "dist/*.d.ts",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**",
      "dist/meta.json"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "imports": {
    "viem": "npm:viem@2.46.2",
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.0.1",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.0.12"
  },
  "nodeModulesDir": "auto"
}
