{
  "name": "@dreamer/web3",
  "version": "1.2.0",
  "description": "Web3 (EVM) utilities for Deno/Bun/Node.",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client/mod.ts"
  },
  "scripts": {
    "test": "bun test tests/utils.test.ts tests/client-mod.test.ts",
    "test:node": "tsx --tsconfig tsconfig.json --test --test-force-exit tests/utils.test.ts tests/client-mod.test.ts",
    "test:integration": "bun test tests/mod.test.ts",
    "build": "deno run -A build-browser.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/"
  },
  "dependencies": {
    "@dreamer/i18n": "npm:@jsr/dreamer__i18n@^1.1.2",
    "@dreamer/runtime-adapter": "npm:@jsr/dreamer__runtime-adapter@^1.2.2",
    "@dreamer/service": "npm:@jsr/dreamer__service@^1.1.0",
    "viem": "2.46.2"
  },
  "devDependencies": {
    "@dreamer/test": "npm:@jsr/dreamer__test@^1.2.3",
    "tsx": "^4.23.1"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "keywords": [
    "web3",
    "evm",
    "viem",
    "dreamer"
  ]
}
